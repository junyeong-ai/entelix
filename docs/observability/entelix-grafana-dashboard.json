{
  "annotations": {
    "list": []
  },
  "description": "entelix SDK — production observability reference. Surfaces every cost-bearing operation per tenant, plus graph depth and tool error rates. Queries assume Tempo + Loki + tracing-opentelemetry pipeline.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Model spend (per tenant, per model)",
      "description": "Sums gen_ai.usage.cost across all chat-model invocations grouped by (entelix.tenant_id, gen_ai.response.model). Source: OtelLayer with_cost_calculator.",
      "type": "timeseries",
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{ name=\"gen_ai.response\" } | sum_over_time(gen_ai.usage.cost) by (entelix.tenant_id, gen_ai.response.model)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] }
    },
    {
      "id": 2,
      "title": "Tool spend (per tenant, per tool)",
      "description": "gen_ai.tool.cost from successful tool dispatches. F4 guarantees no charge on the error path.",
      "type": "timeseries",
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{ name=\"gen_ai.tool.end\" } | sum_over_time(gen_ai.tool.cost) by (entelix.tenant_id, gen_ai.tool.name)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] }
    },
    {
      "id": 3,
      "title": "Embedding spend (per tenant, per model)",
      "description": "gen_ai.embedding.cost from MeteredEmbedder wrapping the operator's chosen embedder.",
      "type": "timeseries",
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{ name=\"gen_ai.embedding.end\" } | sum_over_time(gen_ai.embedding.cost) by (entelix.tenant_id, gen_ai.embedding.model)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] }
    },
    {
      "id": 4,
      "title": "Tokens — input vs output (per tenant)",
      "description": "Token volume by direction. Spikes here precede cost spikes by exactly the call latency.",
      "type": "timeseries",
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{ name=\"gen_ai.response\" } | sum_over_time(gen_ai.usage.input_tokens) by (entelix.tenant_id)"
        },
        {
          "refId": "B",
          "queryType": "traceql",
          "query": "{ name=\"gen_ai.response\" } | sum_over_time(gen_ai.usage.output_tokens) by (entelix.tenant_id)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 5,
      "title": "Tool error rate (per tool)",
      "description": "gen_ai.tool.error / gen_ai.tool.end ratio. Heatmap reveals which tool started flapping.",
      "type": "heatmap",
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{ name=\"gen_ai.tool.error\" } | count_over_time() by (gen_ai.tool.name)"
        }
      ]
    },
    {
      "id": 6,
      "title": "Graph recursion depth (p50 / p95 / p99)",
      "description": "entelix.graph.depth from CompiledGraph::execute_loop. Alert when p99 > 0.8 × recursion_limit — strong signal of impending limit-violation.",
      "type": "timeseries",
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{ name=\"entelix.graph.run_complete\" } | quantile_over_time(entelix.graph.depth, 0.5)"
        },
        {
          "refId": "B",
          "queryType": "traceql",
          "query": "{ name=\"entelix.graph.run_complete\" } | quantile_over_time(entelix.graph.depth, 0.95)"
        },
        {
          "refId": "C",
          "queryType": "traceql",
          "query": "{ name=\"entelix.graph.run_complete\" } | quantile_over_time(entelix.graph.depth, 0.99)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 7,
      "title": "Cancellation rate (per tenant)",
      "description": "entelix.cancelled = true on terminal events. Sustained high values mean clients are tearing down requests mid-flight.",
      "type": "timeseries",
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{ entelix.cancelled = true } | count_over_time() by (entelix.tenant_id)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 8,
      "title": "Model latency p95 (per model)",
      "description": "duration_ms from gen_ai.response — vendor-side latency does not include client retries.",
      "type": "timeseries",
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{ name=\"gen_ai.response\" } | quantile_over_time(duration_ms, 0.95) by (gen_ai.response.model)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["entelix", "gen_ai", "observability"],
  "templating": {
    "list": [
      {
        "name": "DS_TEMPO",
        "type": "datasource",
        "query": "tempo",
        "current": { "text": "default", "value": "default" }
      },
      {
        "name": "tenant_id",
        "type": "query",
        "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
        "query": "{ entelix.tenant_id != \"\" } | by (entelix.tenant_id)",
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "entelix — agent SDK observability",
  "uid": "entelix-prod-overview",
  "version": 1
}
